{
  "name": "raeburnai-business-twin",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Enterprise business digital twin platform for operational scenario modelling.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint src tests --max-warnings=0",
