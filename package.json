    "test:watch": "vitest",
    "verify": "pnpm lint && pnpm format && pnpm typecheck && pnpm test && pnpm build"
  },
  "dependencies": {
    "@types/node": "22.13.14",
    "@types/react": "19.0.12",
    "@types/react-dom": "19.0.4",
    "clsx": "2.1.1",
    "nanoid": "5.1.5",
    "next": "15.3.5",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "zod": "3.25.67"
  },
  "devDependencies": {
    "@eslint/js": "9.30.1",
    "autoprefixer": "10.4.21",
    "eslint": "9.30.1",
    "eslint-config-next": "16.2.10",
    "postcss": "8.5.6",
    "prettier": "3.6.2",
    "tailwindcss": "3.4.17",
    "typescript": "5.8.3",
    "typescript-eslint": "8.35.1",
    "vitest": "3.2.4"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
